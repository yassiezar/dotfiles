{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
      "~/.config/opencode/plugins/caveman/plugin.js"
  ],
  "model": "openai/gpt-5.6-terra",
  "agent": {
    "build": {
      "mode": "primary",
      "model": "openai/gpt-5.6-terra"
    },
    "explore": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-luna-fast"
    },
    "architect": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-sol"
    },
    "general": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-sol"
    },
    "scout": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-luna"
    },
    "compaction": {
      "mode": "primary",
      "model": "openai/gpt-5.6-luna"
    },
    "title": {
      "mode": "primary",
      "model": "openai/gpt-5.6-luna-fast"
    },
    "summary": {
      "mode": "primary",
      "model": "openai/gpt-5.6-luna-fast"
    }
  },
  "autoshare": false,
  "lsp": {
    "python": {
      "command": ["pyright-langserver", "--stdio"],
      "extensions": [".py"]
    },
    "typescript": {
      "command": ["typescript-language-server", "--stdio"],
      "extensions": [".ts", ".tsx", ".js", ".jsx"]
    }
  },
  "formatter": {
    "python": {
      "command": ["ruff", "format"],
      "extensions": [".py"]
    },
    "javascript": {
      "command": ["prettier", "--write"],
      "extensions": [".js", ".jsx", ".ts", ".tsx"]
    },
    "json": {
      "command": ["prettier", "--write"],
      "extensions": [".json", ".jsonc"]
    },
    "go": {
      "command": ["gofmt"],
      "extensions": [".go"]
    }
  }
}
